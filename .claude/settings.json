{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(source ../venv/bin/activate)",
      "Bash(evennia test --settings settings tests.*)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Read(server/conf/secret_settings.py)",
      "Read(server/conf/secret_settings.local)",
      "Read(**/secret_settings.py)",
      "Read(**/secret_settings.py.bak)",
      "Read(**/secret_settings.local)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ],
    "ask": [
      "Bash(evennia test --settings settings)",
      "Bash(git reset *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(git rebase *)",
      "Bash(git push *)"
    ]
  }
}